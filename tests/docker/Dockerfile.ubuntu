FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV CARGO_HOME=/root/.cargo
ENV PATH="/root/.cargo/bin:${PATH}"

# Install system deps (same as install.sh for debian-based)
RUN apt-get update && apt-get install -y \
    curl gcc libc6-dev pkg-config libssl-dev libudev-dev libasound2-dev \
    libclang-dev git ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install Rust
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable

# Copy source
WORKDIR /horus
COPY . .

# Build EVERYTHING inside container (avoids glibc mismatch)
RUN cargo build --no-default-features --release -p horus_core -p horus_library -p horus_sys -p horus_manager

# Default: run horus_sys tests
CMD ["cargo", "test", "--no-default-features", "-p", "horus_sys", "--", "--test-threads=1"]
