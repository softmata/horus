FROM alpine:3.19

ENV CARGO_HOME=/root/.cargo
ENV PATH="/root/.cargo/bin:${PATH}"

# Alpine uses musl libc — tests that horus_sys works on musl (not just glibc)
RUN apk add --no-cache \
    curl gcc musl-dev pkgconf openssl-dev eudev-dev alsa-lib-dev \
    clang-dev git bash

RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable

WORKDIR /horus
COPY . .

RUN cargo build --no-default-features --release -p horus_core -p horus_library -p horus_sys -p horus_manager

CMD ["cargo", "test", "--no-default-features", "-p", "horus_sys", "--", "--test-threads=1"]
