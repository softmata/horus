<?xml version="1.0"?>
<robot name="scout">
  <!-- Small circular scout robot -->
  <link name="base_link">
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.015"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry><cylinder length="0.06" radius="0.10"/></geometry>
      <material name="scout_body">
        <color rgba="0.3 0.3 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry><cylinder length="0.06" radius="0.10"/></geometry>
    </collision>
  </link>

  <!-- Left wheel -->
  <link name="left_wheel">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0002"/>
    </inertial>
    <visual>
      <geometry><cylinder length="0.02" radius="0.03"/></geometry>
      <material name="wheel"><color rgba="0.15 0.15 0.15 1.0"/></material>
    </visual>
    <collision>
      <geometry><cylinder length="0.02" radius="0.03"/></geometry>
    </collision>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0.0 0.11 0.0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.005" friction="0.02"/>
  </joint>

  <!-- Right wheel -->
  <link name="right_wheel">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0002"/>
    </inertial>
    <visual>
      <geometry><cylinder length="0.02" radius="0.03"/></geometry>
      <material name="wheel"/>
    </visual>
    <collision>
      <geometry><cylinder length="0.02" radius="0.03"/></geometry>
    </collision>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0.0 -0.11 0.0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <dynamics damping="0.005" friction="0.02"/>
  </joint>

  <!-- Caster ball -->
  <link name="caster">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00005" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00005"/>
    </inertial>
    <visual>
      <geometry><sphere radius="0.015"/></geometry>
      <material name="wheel"/>
    </visual>
    <collision>
      <geometry><sphere radius="0.015"/></geometry>
    </collision>
  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster"/>
    <origin xyz="-0.08 0 -0.015" rpy="0 0 0"/>
  </joint>
</robot>
